{
    "name": "jsoniq-lsp-workspace",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build": "pnpm run build:server && pnpm run build:client",
        "build:server": "pnpm --filter @jsoniq-lsp/language-server run build",
        "build:client": "pnpm --filter @jsoniq-lsp/vscode-extension run build",
        "generate:grammar": "pnpm --filter @jsoniq-lsp/language-server run generate:grammar",
        "start": "pnpm --filter @jsoniq-lsp/language-server run start",
        "test": "pnpm --filter @jsoniq-lsp/language-server run test",
        "test:samples": "pnpm --filter @jsoniq-lsp/language-server run test:samples"
    }
}
