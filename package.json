{
    "name": "jsoniq-lsp-workspace",
    "private": true,
    "packageManager": "pnpm@11.0.5",
    "scripts": {
        "build": "run-s build:core build:client",
        "build:prod": "pnpm run clean && run-s build:core:prod build:client",
        "build:core": "run-p build:wrapper build:server",
        "build:core:prod": "run-p build:wrapper:prod build:server:prod",
        "build:wrapper": "mvn -f packages/rumble-lsp-wrapper/pom.xml -q package",
        "build:wrapper:prod": "mvn -f packages/rumble-lsp-wrapper/pom.xml -q -Pprod package",
        "build:server": "pnpm --filter @jimmycai/jsoniq-language-server run build",
        "build:server:prod": "pnpm --filter @jimmycai/jsoniq-language-server run build:prod",
        "build:client": "pnpm --filter jsoniq-vscode-extension run build",
        "generate:grammar": "pnpm --filter @jimmycai/jsoniq-language-server run generate:grammar",
        "start": "pnpm --filter @jimmycai/jsoniq-language-server run start",
        "test": "pnpm --filter @jimmycai/jsoniq-language-server run test",
        "clean": "pnpm --filter @jimmycai/jsoniq-language-server run clean && mvn -f packages/rumble-lsp-wrapper/pom.xml -q clean && pnpm --filter jsoniq-vscode-extension run clean",
        "lint:server": "pnpm --filter @jimmycai/jsoniq-language-server run lint",
        "lint:client": "pnpm --filter jsoniq-vscode-extension run lint",
        "lint": "run-p lint:server lint:client",
        "fmt:check:server": "pnpm --filter @jimmycai/jsoniq-language-server run fmt:check",
        "fmt:check:client": "pnpm --filter jsoniq-vscode-extension run fmt:check",
        "fmt:check": "run-p fmt:check:server fmt:check:client"
    },
    "devDependencies": {
        "npm-run-all2": "^8.0.4"
    }
}