{
    "name": "@jsoniq-lsp/language-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        "./server": "./dist/server/main.js"
    },
    "scripts": {
        "generate:grammar": "antlr-ng -Dlanguage=TypeScript --generate-visitor true --generate-listener false --output-directory src/grammar src/grammar/jsoniq.g4",
        "build": "tsc -p tsconfig.json",
        "watch": "tsc -w -p tsconfig.json",
        "start": "node ./dist/server/main.js",
        "test": "vitest run tests",
        "test:samples": "pnpm test -- tests/test-samples.test.ts"
    },
    "dependencies": {
        "antlr-ng": "^1.0.10",
        "antlr4-c3": "^3.4.4",
        "antlr4ng": "^3.0.16",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
