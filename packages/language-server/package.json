{
    "name": "@jimmycai/jsoniq-language-server",
    "version": "0.1.0",
    "private": false,
    "type": "module",
    "files": [
        "dist"
    ],
    "exports": {
        ".": "./dist/main.js"
    },
    "repository": {
        "url": "https://github.com/CaiJimmy/jsoniq-lsp"
    },
    "scripts": {
        "generate:grammar": "antlr-ng -Dlanguage=TypeScript --generate-visitor true --generate-listener false --output-directory src/parser/adapters/jsoniq/grammar src/parser/adapters/jsoniq/grammar/jsoniq.g4",
        "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
        "build:prod": "tsc -p tsconfig.json --sourceMap false && tsc-alias -p tsconfig.json",
        "watch": "tsc -w -p tsconfig.json",
        "start": "node ./dist/main.js",
        "test": "vitest run tests",
        "test:samples": "pnpm test -- tests/test-samples.test.ts",
        "clean": "rm -rf dist",
        "prepack": "pnpm run build:prod"
    },
    "dependencies": {
        "antlr-ng": "^1.0.10",
        "antlr4-c3": "^3.4.4",
        "antlr4ng": "^3.0.16",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsc-alias": "^1.8.17",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
