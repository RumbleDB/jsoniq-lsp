{
    "name": "@jimmycai/jsoniq-language-server",
    "version": "0.1.0",
    "private": false,
    "repository": {
        "url": "https://github.com/CaiJimmy/jsoniq-lsp"
    },
    "files": [
        "dist",
        "assets"
    ],
    "type": "module",
    "exports": {
        ".": "./dist/main.mjs",
        "./notifications": "./dist/notifications/index.mjs",
        "./bundled": "./dist/bundled/main.mjs"
    },
    "scripts": {
        "generate:grammar": "antlr-ng -Dlanguage=TypeScript --generate-listener true --output-directory src/parser/adapters/jsoniq/grammar src/parser/adapters/jsoniq/grammar/jsoniq.g4",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "build": "pnpm run typecheck && tsdown",
        "build:prod": "pnpm run build",
        "watch": "tsc -w -p tsconfig.json",
        "start": "node ./dist/main.mjs",
        "test": "vitest run tests",
        "clean": "rm -rf dist",
        "prepack": "pnpm run build:prod",
        "ensure-wrapper": "node ./dist/wrapper/executable/ensure-wrapper.mjs",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "dependencies": {
        "antlr-ng": "^1.0.10",
        "antlr4-c3": "^3.4.4",
        "antlr4ng": "^3.0.16",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "tsc-alias": "^1.8.17",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
