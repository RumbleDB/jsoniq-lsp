{
    "name": "jsoniq-vscode-extension",
    "displayName": "JSONiq Language Support",
    "description": "VS Code client for the JSONiq language server.",
    "version": "0.1.0",
    "private": true,
    "publisher": "local",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "jsoniq",
                "aliases": [
                    "JSONiq"
                ],
                "extensions": [
                    ".jq",
                    ".jsoniq"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "jsoniq",
                "scopeName": "source.jsoniq",
                "path": "./syntaxes/jsoniq.tmLanguage.json"
            }
        ],
        "configurationDefaults": {
            "[jsoniq]": {
                "editor.wordBasedSuggestions": "off",
                "editor.suggest.showWords": false
            }
        }
    },
    "scripts": {
        "build": "pnpm run clean && pnpm run typecheck && rolldown -c",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "watch": "rolldown -c -w",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@jimmycai/jsoniq-language-server": "workspace:*",
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "rolldown": "1.0.0-rc.17",
        "typescript": "^6.0.3"
    }
}
