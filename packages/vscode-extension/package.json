{
    "name": "jsoniq-vscode-extension",
    "displayName": "JSONiq Language Support",
    "version": "1.0.0",
    "private": true,
    "description": "VS Code client for the JSONiq language server.",
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "url": "https://github.com/CaiJimmy/jsoniq-lsp"
    },
    "publisher": "RumbleDB",
    "main": "./dist/extension.js",
    "scripts": {
        "build": "pnpm run clean && pnpm run typecheck && rolldown -c",
        "build:prod": "pnpm run clean && pnpm run typecheck && rolldown -c  --environment BUILD:production",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "watch": "rolldown -c -w",
        "clean": "rm -rf dist",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "dependencies": {
        "@jimmycai/jsoniq-language-server": "workspace:*",
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.6.1",
        "@types/vscode": "^1.118.0",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "rolldown": "1.0.0",
        "typescript": "^6.0.3"
    },
    "contributes": {
        "languages": [
            {
                "id": "jsoniq",
                "aliases": [
                    "JSONiq"
                ],
                "extensions": [
                    ".jq",
                    ".jsoniq"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "jsoniq",
                "scopeName": "source.jsoniq",
                "path": "./syntaxes/jsoniq.tmLanguage.json"
            },
            {
                "scopeName": "source.jsoniq-notebook-injection",
                "path": "./syntaxes/jsoniq-notebook-injection.tmLanguage.json",
                "injectTo": [
                    "source.python"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.jsoniq": "jsoniq"
                }
            }
        ],
        "configurationDefaults": {
            "[jsoniq]": {
                "editor.wordBasedSuggestions": "off",
                "editor.suggest.showWords": false
            }
        }
    },
    "activationEvents": [
        "onNotebook:jupyter-notebook"
    ],
    "engines": {
        "vscode": "^1.118.0"
    }
}
